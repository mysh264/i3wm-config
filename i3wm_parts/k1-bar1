#############################################
# Bar1 settings (input comes from i3blocks) #
#############################################

# bar toggle, hide or show
bindsym $mod+m bar mode toggle

# Start i3bar to display a workspace bar
# (plus the system information i3status finds out, if available)
bar {
        font pango: Noto Sans Regular 13

            status_command i3blocks -c ~/.config/i3/i3blocks.conf
            position bottom
#           i3bar_command i3bar --transparency
# it could be that you have no primary display set: set one (xrandr --output <output> --primary)
# reference: https://i3wm.org/docs/userguide.html#_tray_output
            #tray_output primary
            tray_padding 8
            #padding 5px 0 5px 0

# When strip_workspace_numbers is set to yes,
# any workspace that has a name of the form
# “[n][:][NAME]” will display only the name.
# strip_workspace_numbers yes
# strip_workspace_name no


        colors {
		background $bg-color
	    separator $separator
		#                  border             background         text
		focused_workspace  $bg-color          $bg-color          $text-color
		inactive_workspace $inactive-bg-color $inactive-bg-color $inactive-text-color
		urgent_workspace   $bg-color          $bg-color          $urgent-text-color
	}

        # Right click to go to workspace 10
        $sym button3 workspace $ws10
	
        # Display mode
          #mode hide # dock|hide|invisible
          #hidden_state hide # hide|show
          #modifier Mod1 
          #modifier Ctrl
          #modifier off
        ## https://i3wm.org/docs/userguide.html#_display_mode

}

